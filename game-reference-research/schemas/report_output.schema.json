    "game_identity": {"type": "object"},
    "core_loop": {"type": "object"},
    "player_experience": {"type": "object"},
    "systems": {"type": "array", "items": {"type": "object"}},
    "ux_ui": {"type": "array", "items": {"type": "object"}},
    "visual_style": {"type": "object"},
