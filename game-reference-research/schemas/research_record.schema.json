{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GameReferenceResearchRecord",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "reference_id",
    "title",
    "source_type",
    "source_owner",
    "url",
    "date_accessed",
    "game_titles",
    "platforms",
    "research_domains",
    "claims",
    "evidence_items",
    "confidence",
    "rights_or_license",
    "needs_human_check"
  ],
  "properties": {
    "reference_id": {"type": "string"},
    "title": {"type": ["string", "null"]},
    "source_type": {
      "type": "string",
      "enum": ["user_provided", "direct_play", "official", "platform_store", "database", "professional", "academic", "curated_archive", "community", "unknown"]
    },
    "source_owner": {"type": ["string", "null"]},
    "url": {"type": ["string", "null"]},
    "date_published": {"type": ["string", "null"]},
    "date_accessed": {"type": ["string", "null"]},
    "game_titles": {"type": "array", "items": {"type": "string"}},
    "platforms": {"type": "array", "items": {"type": "string"}},
    "research_domains": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["core_loop", "mechanics", "systems", "ux_ui", "onboarding", "visual_style", "game_feel", "level_design", "technical_architecture", "monetization", "accessibility", "market_context", "credits", "other"]
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["claim", "claim_type", "confidence", "supporting_evidence_ids"],
        "properties": {
          "claim": {"type": "string"},
          "claim_type": {"type": "string", "enum": ["observed", "confirmed", "inferred", "unknown"]},
          "confidence": {"type": "string", "enum": ["high", "medium", "low", "unknown"]},
          "supporting_evidence_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_id", "description", "source_location", "evidence_kind"],
        "properties": {
          "evidence_id": {"type": "string"},
          "description": {"type": "string"},
          "source_location": {"type": ["string", "null"]},
          "evidence_kind": {"type": "string", "enum": ["screenshot", "video_timestamp", "store_text", "official_doc", "code", "user_note", "database_field", "article", "other"]}
        }
      }
    },
    "rights_or_license": {"type": ["string", "null"]},
    "confidence": {"type": "string", "enum": ["high", "medium", "low", "unknown"]},
    "needs_human_check": {"type": "array", "items": {"type": "string"}}
  }
}
